```java
// src/main/java/ru/yarskiy/safeguardcontrol/model/SafeGuard.java
package ru.yarskiy.safeguardcontrol.model;

import jakarta.persistence.*;
import java.time.Period;

@Entity
@Table(name = "safe_guards")
public class SafeGuard {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false)
    private String name; // Название объекта (например, "Backup Server", "Payment Gateway")

    @Column(nullable = false)
    private String endpoint; // URL или путь для проверки

    @Column(nullable = false)
    private Period checkInterval; // Как часто проверять (например, PT5M — каждые 5 минут)

    @Column(nullable = false)
    private boolean active = true; // Включён ли мониторинг

    // Конструкторы, геттеры и сеттеры

    public SafeGuard() {}

    public SafeGuard(String name, String endpoint, Period checkInterval) {
        this.name = name;
        this.endpoint = endpoint;
        this.checkInterval = checkInterval;
    }

    // Getters and Setters
    public Long getId() { return id; }
    public void setId(Long id) { this.id = id; }

    public String getName() { return name; }
    public void setName(String name) { this.name = name; }

    public String getEndpoint() { return endpoint; }
    public void setEndpoint(String endpoint) { this.endpoint = endpoint; }

    public Period getCheckInterval() { return checkInterval; }
    public void setCheckInterval(Period checkInterval) { this.checkInterval = checkInterval; }

    public boolean isActive() { return active; }
    public void setActive(boolean active) { this.active = active; }
}
```

> ✅ Обратите внимание: используется `java.time.Period`, но на практике для интервалов лучше подойдёт `Duration` (если нужны минуты/секунды), а `Period` — больше для дат (дни, месяцы, годы). Возможно, стоит заменить позже. Но раз вы уже добавили `StringToPeriodConverter`, возможно, вы используете формат `PnDTnHnMnS`. Уточним позже.

