    @Column(nullable = false)
    private String manufacturer;

    private String specification; // Технические характеристики: например, "до 1000 В", "класс 00"

    private LocalDate issueDate; // Дата ввода в эксплуатацию
    private LocalDate nextTestDate; // Следующая дата проверки (обязательна!)
    private LocalDate lastTestDate; // Последняя проверка

    @Enumerated(EnumType.STRING)
