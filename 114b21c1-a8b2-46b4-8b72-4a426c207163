        this.name = name;
        this.type = type;
        this.specification = specification;
        this.status = EquipmentStatus.РАБОТОСПОСОБНО;
    }

    // Getters and Setters
    public Long getId() { return id; }
    public void setId(Long id) { this.id = id; }

