    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false, unique = true)
    private String inventoryNumber; // Инвентарный номер — уникальный

    @Column(nullable = false)
    private String name; // Наименование: "Указатель напряжения УН-10", "Диэлектрические перчатки Д-2" и т.п.

    @Column(nullable = false)
